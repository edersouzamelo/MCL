generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum RoleName {
  COMMAND_VIEWER
  LOGISTICS_MANAGER
  WAREHOUSE_OPERATOR
  AUDITOR
  ADMIN
  READ_ONLY
}

enum DataNature {
  validado
  informado
  calculado
  estimado
  divergente
  pendente
}

enum SourceOrigin {
  PUBLICO
  SINTETICO
  MANUAL
  CALCULADO
}

enum ExternalProcessingStatus {
  PENDING
  ACCEPTED
  UPDATED
  DUPLICATE
  REJECTED
  QUARANTINED
}

enum ConnectorRunStatus {
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

enum CatalogMappingStatus {
  ACTIVE
  REVOKED
  SUPERSEDED
}

enum CoverageQueryKind {
  CATMAT_SEARCH
  ARP_SEARCH
  ARP_UNITS
}

enum CoverageQueryStatus {
  SUCCESS
  FAILED
  NO_RESULTS
  SKIPPED
}

enum LogisticsUnitState {
  IDENTIFICADO
  AGUARDANDO_INSPECAO
  DISPONIVEL
  ARMAZENADO
  RESERVADO
  SEPARADO
  EM_TRANSITO
  ENTREGUE
}

model User {
  id                   String      @id
  name                 String?
  email                String?     @unique
  image                String?
  active               Boolean     @default(true)
  rank                 String?
  address              String?
  phone                String?
  whatsapp             String?
  militaryRole         String?
  militaryOrganization String?
  termsAcceptedAt      DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  scopes               UserScope[]
  memberships          Membership[]
}

model UserScope {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  supplyClass    String
  role           RoleName
  validFrom      DateTime
  validUntil     DateTime?
  active         Boolean      @default(true)
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Organization {
  id        String      @id
  code      String      @unique
  name      String
  type      String
  parentId  String?
  synthetic Boolean     @default(true)
  active                 Boolean                 @default(true)
  scopes                 UserScope[]
  memberships            Membership[]
  needs                  Need[]
  procurementInstruments ProcurementInstrument[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model SupplyItem {
  id              String        @id
  persistentCode  String        @unique
  name            String
  description     String
  supplyClass     String
  category        String
  baseUnit        String
  active          Boolean       @default(true)
  synthetic       Boolean       @default(true)
  sourceSystem    String?
  sourceRecordId  String?
  sourceOrigin    SourceOrigin?
  sourceUpdatedAt DateTime?
  variants        ItemVariant[]
}

model ItemVariant {
  id     String     @id
  itemId String
  sku    String     @unique
  label  String
  size   String
  unit   String
  active Boolean    @default(true)
  item   SupplyItem @relation(fields: [itemId], references: [id])
  needs  Need[]
  lots   Lot[]
}

model Need {
  id                String      @id
  persistentCode    String      @unique
  organizationId    String
  itemVariantId     String
  quantityRequested Int
  quantityApproved  Int
  priority          String
  requiredAt        DateTime
  purpose           String
  status            String
  sourceSystem      String
  sourceRecordId    String
  authorityLevel    String
  confidence        Float
  schemaVersion     String
  dataNature        DataNature
  occurredAt        DateTime
  recordedAt        DateTime
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  variant           ItemVariant        @relation(fields: [itemVariantId], references: [id])
  organization      Organization       @relation(fields: [organizationId], references: [id])
  needItems         NeedItem[]
  coverageAnalyses  CoverageAnalysis[]
}

model Credit {
  id              String     @id
  persistentCode  String     @unique
  amount          Decimal
  availableAmount Decimal
  planningCode    String
  expenseNature   String
  expiresAt       DateTime
  status          String
  sourceSystem    String
  sourceRecordId  String
  confidence      Float
  schemaVersion   String
  dataNature      DataNature
  occurredAt      DateTime
  recordedAt      DateTime
}

model AcquisitionInstrument {
  id                    String        @id
  persistentCode        String        @unique
  type                  String
  reference             String
  supplierNameSynthetic String?
  supplierName          String?
  supplierDocument      String?
  organizationName      String?
  organizationCode      String?
  itemDescription       String?
  itemCode              String?
  quantity              Decimal?
  unitValue             Decimal?
  totalValue            Decimal?
  sourceOrigin          SourceOrigin?
  sourceUrl             String?
  externalReference     String?
  lastSourceUpdateAt    DateTime?
  confidence            Float?
  validFrom             DateTime
  validUntil            DateTime
  capacity              Int           @default(0)
  status                String
  sourceSystem          String
  sourceRecordId        String
}

model Commitment {
  id                      String   @id
  persistentCode          String   @unique
  creditId                String
  acquisitionInstrumentId String
  amount                  Decimal
  issuedAt                DateTime
  status                  String
  sourceSystem            String
  sourceRecordId          String
  confidence              Float
}

model NeedCoverage {
  id           String  @id
  needId       String
  coverageType String
  quantity     Int
  creditId     String?
  commitmentId String?
  status       String
}

model Lot {
  id                         String      @id
  persistentCode             String      @unique
  itemVariantId              String
  quantity                   Int
  manufacturedAt             DateTime?
  receivedAt                 DateTime?
  supplierReferenceSynthetic String
  status                     String
  variant                    ItemVariant @relation(fields: [itemVariantId], references: [id])
}

model Location {
  id             String  @id
  code           String  @unique
  name           String
  organizationId String
  type           String
  synthetic      Boolean @default(true)
}

model LogisticsUnit {
  id                String             @id
  persistentCode    String             @unique
  lotId             String
  itemVariantId     String
  quantity          Int
  unit              String
  qrToken           String             @unique
  currentState      LogisticsUnitState
  currentLocationId String
  condition         String
  confidence        Float
  sourceEventId     String?
  sourceSystem      String
  sourceRecordId    String
  schemaVersion     String
  dataNature        DataNature
  occurredAt        DateTime
  recordedAt        DateTime
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Shipment {
  id                          String    @id
  persistentCode              String    @unique
  originOrganizationId        String
  destinationOrganizationId   String
  plannedDepartureAt          DateTime
  actualDepartureAt           DateTime?
  expectedDeliveryAt          DateTime
  actualDeliveryAt            DateTime?
  status                      String
  transportReferenceSynthetic String
  confidence                  Float
}

model ShipmentUnit {
  shipmentId      String
  logisticsUnitId String
  quantity        Int

  @@id([shipmentId, logisticsUnitId])
}

model DocumentReference {
  id                  String   @id
  title               String
  documentType        String
  repository          String
  externalReference   String
  classificationLabel String
  synthetic           Boolean  @default(true)
  checksum            String?
  createdAt           DateTime @default(now())
}

model ObjectLink {
  id             String        @id
  fromType       String
  fromId         String
  relationType   String
  toType         String
  toId           String
  sourceSystem   String
  sourceRecordId String
  actorId        String?
  justification  String?
  confidence     Float?
  sourceOrigin   SourceOrigin?
  createdAt      DateTime      @default(now())

  @@index([fromType, fromId])
  @@index([toType, toId])
}

model LogisticsEvent {
  id                  String     @id
  persistentCode      String     @unique
  eventType           String
  occurredAt          DateTime
  recordedAt          DateTime
  objectType          String
  objectId            String
  quantity            Int
  unit                String
  locationId          String?
  condition           String?
  sourceSystem        String
  sourceRecordId      String
  actorId             String
  idempotencyKey      String     @unique
  schemaVersion       String
  authorityLevel      String
  confidence          Float
  dataNature          DataNature
  payload             Json
  correctionOfEventId String?
  createdAt           DateTime   @default(now())

  @@index([objectType, objectId])
}

model EventRelation {
  eventId           String
  relatedObjectType String
  relatedObjectId   String
  relationType      String

  @@id([eventId, relatedObjectType, relatedObjectId, relationType])
}

model Divergence {
  id                 String   @id
  persistentCode     String   @unique
  title              String
  severity           String
  status             String
  objectType         String
  objectId           String
  expected           String
  observed           String
  sourceSystem       String
  sourceRecordId     String
  confidence         Float
  detectedAt         DateTime
  correctedByEventId String?
}

model ConnectorHealth {
  id                 String    @id
  name               String
  sourceSystem       String
  status             String
  lastRunAt          DateTime
  lastSuccessAt      DateTime?
  latencyMs          Int
  recordsImported    Int
  quarantinedRecords Int
  message            String
  endpoint           String?
  recordsRead        Int?
  acceptedRecords    Int?
  updatedRecords     Int?
  duplicateRecords   Int?
  rejectedRecords    Int?
  durationMs         Int?
  mappingVersion     String?
  lastRunId          String?
}

model QuarantineRecord {
  id             String   @id
  sourceSystem   String
  sourceRecordId String
  reason         String
  payload        Json
  createdAt      DateTime @default(now())
}

model ExternalRecord {
  id               String                   @id
  connectorId      String
  externalType     String
  externalId       String
  sourceUrl        String
  fetchedAt        DateTime
  sourceUpdatedAt  DateTime?
  schemaVersion    String
  payload          Json
  payloadHash      String
  processingStatus ExternalProcessingStatus
  errorMessage     String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([connectorId, externalType, externalId])
  @@index([connectorId, processingStatus])
  @@index([payloadHash])
}

model ConnectorRun {
  id                 String             @id
  connectorId        String
  status             ConnectorRunStatus
  startedAt          DateTime
  finishedAt         DateTime?
  endpoint           String
  recordsRead        Int
  acceptedRecords    Int
  updatedRecords     Int
  duplicateRecords   Int
  rejectedRecords    Int
  quarantinedRecords Int
  durationMs         Int
  mappingVersion     String
  message            String

  @@index([connectorId, startedAt])
}

model CoverageQuery {
  id               String              @id
  needId           String
  kind             CoverageQueryKind
  endpoint         String
  params           Json
  status           CoverageQueryStatus
  recordsRead      Int
  sourceUrl        String?
  errorMessage     String?
  actorId          String?
  externalCatalog  String?
  externalItemCode String?
  startedAt        DateTime
  finishedAt       DateTime
  staleAt          DateTime?

  @@index([needId, kind, startedAt])
  @@index([externalCatalog, externalItemCode])
}

model CatalogSearchCandidate {
  id                    String    @id
  queryId               String
  needId                String
  externalCatalog       String
  externalItemCode      String
  externalDescription   String
  groupCode             String?
  classCode             String?
  pdmCode               String?
  statusItem            Boolean?
  sourceSystem          String
  sourceUrl             String
  sourceUpdatedAt       DateTime?
  fetchedAt             DateTime
  similarityScore       Float
  similarityExplanation String
  payload               Json

  @@index([needId, queryId])
  @@index([externalCatalog, externalItemCode])
}

model ItemCatalogMapping {
  id                  String               @id
  mclItemId           String
  mclVariantId        String?
  needId              String?
  externalCatalog     String
  externalItemCode    String
  externalDescription String
  groupCode           String?
  classCode           String?
  pdmCode             String?
  confirmedBy         String
  confirmedAt         DateTime
  revokedBy           String?
  revokedAt           DateTime?
  justification       String
  status              CatalogMappingStatus
  confidence          Float
  mappingVersion      Int
  replacesMappingId   String?
  sourceCandidateId   String?

  @@index([mclItemId, mclVariantId, status])
  @@index([needId, status])
  @@index([externalCatalog, externalItemCode])
}

model ArpUnitRecord {
  id                        String    @id
  needId                    String
  acquisitionInstrumentId   String
  numeroAta                 String
  unidadeGerenciadora       String
  numeroItem                String
  codigoUnidade             String?
  nomeUnidade               String?
  tipoUnidade               String?
  fornecedor                String?
  quantidadeRegistrada      Decimal?
  saldoAdesoes              Decimal?
  saldoRemanejamentoEmpenho Decimal?
  qtdLimiteAdesao           Decimal?
  qtdLimiteInformadoCompra  Decimal?
  aceitaAdesao              Boolean?
  sourceUrl                 String
  sourceUpdatedAt           DateTime?
  fetchedAt                 DateTime
  payload                   Json

  @@unique([needId, acquisitionInstrumentId, codigoUnidade])
  @@index([numeroAta, unidadeGerenciadora, numeroItem])
}

model AuditLog {
  id             String   @id
  occurredAt     DateTime
  actorId        String
  action         String
  resourceType   String
  resourceId     String
  organizationId String?
  requestId      String
  sourceIpHash   String?
  userAgent      String
  outcome        String
  reason         String
  metadata       Json
}

model MaterialCoverageAnalysis {
  id                         String    @id
  needId                     String
  itemId                     String
  variantId                  String?
  status                     String
  deficitQuantity            Int
  requestedQuantity          Int
  availableStockQuantity     Int
  reservedQuantity           Int
  deliveredQuantity          Int
  confirmedCatalogMappingId  String?
  startedBy                  String
  startedAt                  DateTime
  completedAt                DateTime?
  lastRefreshAt              DateTime?
  confidence                 Float
  summaryVersion             Int
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([needId])
  @@index([itemId])
}

model AcquisitionCoverageCandidate {
  id                       String   @id
  analysisId               String
  acquisitionInstrumentId  String
  externalItemCode         String
  potentialQuantity        Int
  committedQuantity        Int?
  reportedBalance          Int?
  unitValue                Float?
  validityStatus           String
  evidenceLevel            String
  confidence               Float
  limitations              String[]
  selectedByUser           Boolean
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([analysisId])
  @@index([acquisitionInstrumentId])
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

enum IntegrationStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum MappingStatus {
  ACTIVE
  INACTIVE
  SUPERSEDED
}

enum ProcurementStatus {
  ACTIVE
  INACTIVE
  COMPLETED
  CANCELLED
}

enum CoverageStatus {
  PENDING
  SUCCESS
  FAILED
  PARTIAL
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
}

model Membership {
  id             String           @id @default(uuid())
  userId         String
  organizationId String
  roleId         String
  status         MembershipStatus @default(ACTIVE)
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, roleId])
  @@index([userId])
  @@index([organizationId])
  @@index([roleId])
}

model IntegrationRun {
  id             String            @id @default(uuid())
  integrationKey String
  status         IntegrationStatus
  startedAt      DateTime          @default(now())
  finishedAt     DateTime?
  durationMs     Int?
  recordsTotal   Int               @default(0)
  recordsSuccess Int               @default(0)
  recordsFailed  Int               @default(0)
  errorMessage   String?
  logs           IntegrationLog[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([integrationKey, status])
}

model IntegrationLog {
  id               String         @id @default(uuid())
  runId            String
  level            LogLevel
  message          String
  sourceSystem     String
  sourceRecordId   String?
  payloadSanitized Json?
  occurredAt       DateTime       @default(now())
  run              IntegrationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([level])
}

model Item {
  id              String                      @id @default(uuid())
  code            String                      // Índice simples
  name            String
  description     String?
  category        String?
  active          Boolean                     @default(true)
  sourceSystem    String?
  sourceRecordId  String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  catmatMappings  CatmatMapping[]
  needItems       NeedItem[]
  instrumentItems ProcurementInstrumentItem[]
  coverageResults CoverageResult[]

  @@index([code])
  @@unique([sourceSystem, sourceRecordId])
}

model CatmatMapping {
  id               String        @id @default(uuid())
  itemId           String
  catmatCode       String
  description      String
  confidence       Float         @default(1.0)
  status           MappingStatus @default(ACTIVE)
  justification    String?
  sourceSystem     String?
  sourceRecordId   String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  item             Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, catmatCode])
  @@index([itemId])
  @@index([catmatCode])
}

model NeedItem {
  id             String   @id @default(uuid())
  needId         String
  itemId         String
  quantity       Decimal
  unit           String
  status         String   @default("PENDING")
  sourceSystem   String?
  sourceRecordId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  need           Need     @relation(fields: [needId], references: [id], onDelete: Cascade)
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([needId])
  @@index([itemId])
}

model ProcurementInstrument {
  id              String                      @id @default(uuid())
  type            String                      // ATA, CONTRATO, EDITAL, etc.
  code            String                      @unique
  organizationId  String?
  status          ProcurementStatus           @default(ACTIVE)
  validFrom       DateTime?
  validUntil      DateTime?
  sourceSystem    String?
  sourceRecordId  String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  items           ProcurementInstrumentItem[]
  organization    Organization?               @relation(fields: [organizationId], references: [id])
  coverageResults CoverageResult[]

  @@index([organizationId])
}

model ProcurementInstrumentItem {
  id                      String                     @id @default(uuid())
  procurementInstrumentId String
  itemId                  String
  quantity                Decimal
  unitValue               Decimal
  totalValue              Decimal
  unit                    String
  sourceSystem            String?
  sourceRecordId          String?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  procurementInstrument   ProcurementInstrument      @relation(fields: [procurementInstrumentId], references: [id], onDelete: Cascade)
  item                    Item                       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  coverageResults         CoverageResult[]

  @@index([procurementInstrumentId])
  @@index([itemId])
}

model CoverageAnalysis {
  id         String           @id @default(uuid())
  needId     String
  status     CoverageStatus   @default(PENDING)
  startedBy  String?
  startedAt  DateTime         @default(now())
  finishedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  need       Need             @relation(fields: [needId], references: [id], onDelete: Cascade)
  results    CoverageResult[]

  @@index([needId])
}

model CoverageResult {
  id                 String                     @id @default(uuid())
  coverageAnalysisId String
  itemId             String
  quantityCovered    Decimal
  deficitQuantity    Decimal
  unit               String
  instrumentId       String?
  instrumentItemId   String?
  confidence         Float                      @default(1.0)
  sourceSystem       String?
  sourceRecordId     String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  coverageAnalysis   CoverageAnalysis           @relation(fields: [coverageAnalysisId], references: [id], onDelete: Cascade)
  item               Item                       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  instrument         ProcurementInstrument?      @relation(fields: [instrumentId], references: [id])
  instrumentItem     ProcurementInstrumentItem? @relation(fields: [instrumentItemId], references: [id])

  @@index([coverageAnalysisId])
  @@index([itemId])
  @@index([instrumentId])
  @@index([instrumentItemId])
}

model EventLog {
  id              String   @id @default(uuid())
  eventType       String
  objectType      String
  objectId        String
  occurredAt      DateTime
  recordedAt      DateTime @default(now())
  sourceSystem    String   @default("MCL")
  sourceRecordId  String?
  actorId         String?
  schemaVersion   String   @default("1.0")
  integrityStatus String   @default("PENDING")
  idempotencyKey  String   @unique
  relatedObjects  Json?
  quantityValue   Decimal?
  quantityUnit    String?
  locationId      String?
  condition       String?
  createdAt       DateTime @default(now())

  @@index([eventType])
  @@index([objectType, objectId])
  @@index([occurredAt])
}

